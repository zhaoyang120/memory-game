.progress-bar { font-size: 30rpx; color: #4A90E2; font-weight: bold; margin-bottom: 30rpx; }
.question-card {
  background: #FFFFFF;
  width: 100%;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}
.question-text { font-size: 36rpx; font-weight: bold; color: #1F2D3D; line-height: 1.5; }
.options-container { width: 100%; }
.option-btn {
  background: #FFFFFF;
  border: 2rpx solid #E4E7ED;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 32rpx;
  color: #303133;
  margin-bottom: 24rpx;
  text-align: center;
}
.option-btn.correct { background: #67C23A; color: #FFFFFF; border-color: #67C23A; }
.option-btn.wrong { background: #F56C6C; color: #FFFFFF; border-color: #F56C6C; }
