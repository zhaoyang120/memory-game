.result-header { text-align: center; margin-bottom: 30rpx; }
.result-title { font-size: 44rpx; font-weight: bold; color: #1F2D3D; }
.result-score { font-size: 32rpx; color: #4A90E2; margin-top: 10rpx; }
.new-title-badge {
  display: inline-block;
  background: #FFF0F0;
  color: #FF4D4F;
  font-weight: bold;
  font-size: 28rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-top: 15rpx;
}
.promo-card {
  background: #FFFFFF;
  width: 100%;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 40rpx;
  border: 2rpx solid #FFE58F;
}
.promo-title { font-size: 36rpx; font-weight: bold; color: #D46B08; }
.promo-subtitle { font-size: 26rpx; color: #8C8C8C; margin: 10rpx 0 20rpx 0; }
.qr-code { width: 320rpx; height: 320rpx; margin: 0 auto; border-radius: 12rpx; }
.promo-tips { font-size: 22rpx; color: #BFBFBF; margin-top: 12rpx; }
