page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.4);
  border: none;
  margin: 20rpx 0;
  text-align: center;
}

.btn-secondary {
  background: #FFFFFF;
  color: #4A90E2;
  font-size: 32rpx;
  border-radius: 50rpx;
  padding: 20rpx 50rpx;
  border: 2rpx solid #4A90E2;
  margin: 15rpx 0;
  text-align: center;
}
